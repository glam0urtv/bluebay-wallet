generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  email        String?  @unique
  fullName     String
  pinHash      String
  role         String   @default("user")
  avatarUrl    String?
  isActive     Boolean  @default(true)
  biometricId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet                  Wallet?
  merchant                Merchant?
  createdTokens           Token[]
  nfcSessionsSent         NFCSession[]  @relation("UserSentNFC")
  nfcSessionsReceived     NFCSession[]  @relation("UserReceivedNFC")
  qrSessions              QRSession[]
  auditLogs               AuditLog[]

  @@index([phone])
  @@index([role])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Float    @default(0)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentTransactions     Transaction[] @relation("TxFromWallet")
  receivedTransactions Transaction[] @relation("TxToWallet")
}

model Token {
  id          String   @id @default(uuid())
  name        String
  symbol      String   @unique
  iconUrl     String?
  description String?
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())

  admin        User          @relation(fields: [createdBy], references: [id])
  transactions Transaction[]

  @@index([symbol])
}

model Transaction {
  id              String    @id @default(uuid())
  fromWalletId    String?
  toWalletId      String?
  amount          Float
  tokenId         String?
  type            String
  status          String    @default("pending")
  idempotencyKey  String    @unique
  nfcSessionId    String?
  qrSessionId     String?
  note            String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  fromWallet  Wallet?     @relation("TxFromWallet", fields: [fromWalletId], references: [id])
  toWallet    Wallet?     @relation("TxToWallet", fields: [toWalletId], references: [id])
  token       Token?      @relation(fields: [tokenId], references: [id])
  nfcSession  NFCSession? @relation(fields: [nfcSessionId], references: [id])
  qrSession   QRSession?  @relation(fields: [qrSessionId], references: [id])

  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([idempotencyKey])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model NFCSession {
  id             String    @id @default(uuid())
  senderUserId   String
  receiverUserId String?
  amount         Float
  nonce          String    @unique
  status         String    @default("pending")
  expiresAt      DateTime
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  sender       User          @relation("UserSentNFC", fields: [senderUserId], references: [id])
  receiver     User?         @relation("UserReceivedNFC", fields: [receiverUserId], references: [id])
  transactions Transaction[]

  @@index([nonce])
  @@index([status])
}

model QRSession {
  id           String    @id @default(uuid())
  senderUserId String
  amount       Float
  token        String    @unique
  status       String    @default("pending")
  expiresAt    DateTime
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  sender       User          @relation(fields: [senderUserId], references: [id])
  transactions Transaction[]

  @@index([token])
  @@index([status])
}

model Merchant {
  id                 String   @id @default(uuid())
  userId             String   @unique
  businessName       String
  businessCategory   String?
  settlementAccount  String?
  conversionRate     Float    @default(1.0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  settlements Settlement[]

  @@index([userId])
}

model Settlement {
  id              String    @id @default(uuid())
  merchantId      String
  totalTokens     Float
  convertedAmount Float
  periodStart     DateTime
  periodEnd       DateTime
  status          String    @default("pending")
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime  @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
